/**
 * OpenClaw_Custom 模型安全配置示例
 * 
 * 使用方法：
 * 1. 复制此文件到 ~/.openclaw/openclaw-custom/models-security.json5
 * 2. 根据实际需求修改配置
 * 3. 重启 OpenClaw 服务
 * 
 * 配置说明：
 * - 支持 JSON5 格式（允许注释和尾随逗号）
 * - 所有配置项均有默认值，无需全部配置
 * - 环境变量可覆盖配置文件（OPENCLAW_MODEL_SECURITY_*）
 */

{
  // ============================================
  // 基础配置
  // ============================================
  
  // 默认区域偏好: 'cn' | 'global' | 'local' | 'auto'
  defaultRegion: 'cn',
  
  // 调试模式（输出详细日志）
  debug: false,
  
  // ============================================
  // 模型白名单
  // ============================================
  
  // 允许使用的模型（空数组表示允许所有）
  allowedModels: [
    // 国内模型
    'moonshot/kimi-k2.5',
    'moonshot/kimi-k2-thinking',
    'kimi-coding/k2p5',
    'zai/glm-5',
    'zai/glm-5-air',
    'qianfan/ernie-4',
    
    // 本地模型
    'ollama/qwen3.5:9b',
    'ollama/qwen3.5:0.8b',
    'ollama/deepseek-coder',
    'lmstudio/*',
    
    // 国际模型（可选）
    'anthropic/claude-sonnet-4-5'
  ],
  
  // 禁止使用的模型（优先级高于 allowedModels）
  blockedModels: [
    // 'anthropic/claude-opus-4-6'  // 示例：禁用昂贵模型
  ],
  
  // ============================================
  // 故障转移配置
  // ============================================
  
  failover: {
    // 启用自动故障转移
    enabled: true,
    
    // 故障转移链（按优先级排序）
    chain: [
      { model: 'moonshot/kimi-k2.5', region: 'cn' },
      { model: 'ollama/qwen3.5:9b', region: 'local' },
      { model: 'anthropic/claude-sonnet-4-5', region: 'global' }
    ],
    
    // 健康检查配置
    healthCheck: {
      interval: 60000,      // 每分钟检查一次
      timeout: 5000,        // 5秒超时
      failureThreshold: 3,  // 连续3次失败认为不可用
      successThreshold: 2   // 连续2次成功认为已恢复
    },
    
    // 冷却时间（模型失败后多久再次尝试）
    cooldownPeriod: 300000,  // 5分钟
    
    // 告警通知
    notifications: {
      enabled: true,
      channels: ['log']  // 可选: 'log', 'webhook', 'email', 'slack'
    }
  },
  
  // ============================================
  // 区域路由策略
  // ============================================
  
  regionRouting: {
    // 国内模型配置
    cn: {
      providers: ['moonshot', 'zai', 'qianfan', 'opencode', 'opencode-go'],
      dataResidencyCheck: true,
      sensitivePatterns: [
        '身份证',
        '银行卡',
        '手机号',
        '护照',
        '病历',
        '密码',
        '密钥',
        'api[_-]?key',
        'token'
      ]
    },
    
    // 本地模型配置
    local: {
      providers: ['ollama', 'lmstudio', 'vllm'],
      endpoints: {
        ollama: 'http://localhost:11434/v1',
        lmstudio: 'http://127.0.0.1:1234/v1',
        vllm: 'http://localhost:8000/v1'
      }
    },
    
    // 国际模型配置
    global: {
      providers: ['anthropic', 'openai', 'google'],
      complianceCheck: {
        allowDataOutbound: false,     // 禁止数据出境
        requireConfirmation: true     // 需要用户确认
      }
    }
  },
  
  // ============================================
  // 内容分级路由
  // ============================================
  
  contentClassification: {
    enabled: true,
    
    rules: [
      {
        name: 'sensitive-data',
        // 匹配敏感数据（身份证、银行卡等）
        patterns: [
          '\\d{17}[\\dXx]',  // 身份证号
          '\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}',  // 银行卡
          '1[3-9]\\d{9}',  // 手机号
          '密码[:：]\\s*\\S+',
          'api[_-]?key[:：]\\s*\\S+',
          'secret[:：]\\s*\\S+'
        ],
        action: {
          type: 'route',
          target: 'ollama/qwen3.5:9b'  // 路由到本地模型
        },
        priority: 100  // 高优先级
      },
      {
        name: 'code-task',
        // 编程相关任务
        patterns: [
          '编程',
          '写代码',
          'debug',
          'refactor',
          '代码审查',
          '代码优化',
          '\\b(function|class|interface|import|export)\\b'
        ],
        action: {
          type: 'route',
          target: 'kimi-coding/k2p5'  // 使用编程专用模型
        },
        priority: 50
      },
      {
        name: 'creative-writing',
        // 创意写作
        patterns: [
          '写小说',
          '创作故事',
          '写诗歌',
          '剧本',
          '文案'
        ],
        action: {
          type: 'route',
          target: 'zai/glm-5'
        },
        priority: 30
      }
    ],
    
    defaultRoute: {
      target: 'moonshot/kimi-k2.5'
    }
  },
  
  // ============================================
  // 访问控制
  // ============================================
  
  accessControl: {
    enabled: true,
    defaultPolicy: 'allowlist',
    permissions: [
      {
        role: 'admin',
        allow: ['*'],
        deny: []
      },
      {
        role: 'developer',
        allow: ['moonshot/*', 'ollama/*', 'anthropic/claude-sonnet-4-5'],
        deny: ['anthropic/claude-opus-4-6']
      },
      {
        role: 'guest',
        allow: ['moonshot/kimi-k2.5', 'ollama/qwen3.5:0.8b'],
        deny: ['*']
      }
    ],
    
    rateLimit: {
      enabled: true,
      default: {
        windowMs: 60000,
        maxRequests: 30
      },
      byRole: {
        admin: { windowMs: 60000, maxRequests: 1000 },
        developer: { windowMs: 60000, maxRequests: 100 },
        guest: { windowMs: 60000, maxRequests: 10 }
      },
      byModel: {
        'anthropic/claude-opus-4-6': { windowMs: 60000, maxRequests: 5 }
      }
    }
  },
  
  // ============================================
  // 凭证管理
  // ============================================
  
  credentials: {
    encryption: {
      algorithm: 'aes-256-gcm',
      keySource: 'env',
      keyEnvVar: 'OPENCLAW_MASTER_KEY'
    },
    rotation: {
      enabled: false,
      interval: '90d',
      alertBefore: '7d'
    },
    storage: {
      type: 'file',
      file: {
        path: '~/.openclaw/secure/credentials.enc'
      }
    }
  },
  
  // ============================================
  // 审计日志
  // ============================================
  
  audit: {
    enabled: true,
    events: [
      'model-switch',
      'model-failover',
      'policy-violation'
    ],
    level: 'info',
    storage: {
      type: 'file',
      file: {
        path: '~/.openclaw/audit/model-security.log',
        rotation: {
          enabled: true,
          maxSize: '10MB',
          maxFiles: 10
        }
      }
    },
    redaction: {
      enabled: true,
      fields: ['apiKey', 'token', 'password', 'secret']
    },
    retention: {
      duration: '90d',
      archive: {
        enabled: true,
        path: '~/.openclaw/audit/archive/'
      }
    }
  }
}
