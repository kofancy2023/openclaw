/**
 * OpenClaw_Custom 模型安全配置 - 本地开发环境
 * 
 * 使用方法：
 * 1. 此文件会自动加载（位于 config/models-security.local.json5）
 * 2. 或设置环境变量: OPENCLAW_MODEL_SECURITY_CONFIG=./config/models-security.local.json5
 */

{
  // ============================================
  // 基础配置
  // ============================================
  
  // 默认区域偏好: 'cn' | 'global' | 'local' | 'auto'
  defaultRegion: 'local',
  
  // 调试模式（输出详细日志）
  debug: true,
  
  // ============================================
  // 模型白名单
  // ============================================
  
  // 允许使用的模型（空数组表示允许所有）
  allowedModels: [
    // 本地模型
    'ollama/qwen2.5:14b',
    'ollama/qwen2.5:7b',
    'ollama/qwen2.5:0.5b',
    'ollama/llama3.2',
    'ollama/deepseek-coder',
    'lmstudio/*',
    
    // 国内模型
    'moonshot/kimi-k2.5',
    'moonshot/kimi-k2-thinking',
    'kimi-coding/k2p5',
    
    // 可选：国际模型
    // 'anthropic/claude-sonnet-4-5'
  ],
  
  // 禁止使用的模型
  blockedModels: [],
  
  // ============================================
  // 故障转移配置
  // ============================================
  
  failover: {
    // 启用自动故障转移
    enabled: true,
    
    // 故障转移链（按优先级排序）
    chain: [
      { model: 'ollama/qwen2.5:7b', region: 'local' },
      { model: 'moonshot/kimi-k2.5', region: 'cn' }
    ],
    
    // 健康检查配置
    healthCheck: {
      interval: 60000,
      timeout: 5000,
      failureThreshold: 3,
      successThreshold: 2
    },
    
    // 冷却时间（模型失败后多久再次尝试）
    cooldownPeriod: 300000,
    
    // 告警通知
    notifications: {
      enabled: true,
      channels: ['log']
    }
  },
  
  // ============================================
  // 区域路由策略
  // ============================================
  
  regionRouting: {
    // 国内模型配置
    cn: {
      providers: ['moonshot', 'zai', 'qianfan'],
      dataResidencyCheck: true,
      sensitivePatterns: [
        '身份证',
        '银行卡',
        '手机号',
        '护照',
        '病历',
        '密码',
        '密钥',
        'api[_-]?key',
        'token'
      ]
    },
    
    // 本地模型配置
    local: {
      providers: ['ollama', 'lmstudio'],
      endpoints: {
        ollama: 'http://localhost:11434/v1',
        lmstudio: 'http://127.0.0.1:1234/v1'
      }
    },
    
    // 国际模型配置
    global: {
      providers: ['anthropic', 'openai'],
      complianceCheck: {
        allowDataOutbound: false,
        requireConfirmation: true
      }
    }
  },
  
  // ============================================
  // 内容分级路由
  // ============================================
  
  contentClassification: {
    enabled: true,
    
    rules: [
      {
        name: 'sensitive-data',
        // 匹配敏感数据（身份证、银行卡等）
        patterns: [
          '\\d{17}[\\dXx]',
          '\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}',
          '1[3-9]\\d{9}',
          '密码[:：]\\s*\\S+',
          'api[_-]?key[:：]\\s*\\S+',
          'secret[:：]\\s*\\S+'
        ],
        action: {
          type: 'route',
          target: 'ollama/qwen2.5:7b'
        },
        priority: 100
      },
      {
        name: 'code-task',
        // 编程相关任务
        patterns: [
          '编程',
          '写代码',
          'debug',
          'refactor',
          '代码审查',
          '代码优化',
          '\\b(function|class|interface|import|export)\\b'
        ],
        action: {
          type: 'route',
          target: 'kimi-coding/k2p5'
        },
        priority: 50
      }
    ],
    
    defaultRoute: {
      target: 'ollama/qwen2.5:7b'
    }
  },
  
  // ============================================
  // 访问控制
  // ============================================
  
  accessControl: {
    enabled: true,
    defaultPolicy: 'allowlist',
    defaultRole: 'developer',
    validRoles: ['admin', 'developer', 'guest'],
    adminUsers: [],
    userRoles: {},
    permissions: [
      {
        role: 'admin',
        allow: ['*'],
        deny: []
      },
      {
        role: 'developer',
        allow: ['moonshot/*', 'ollama/*', 'lmstudio/*'],
        deny: []
      },
      {
        role: 'guest',
        allow: ['ollama/qwen2.5:0.5b'],
        deny: ['*']
      }
    ],
    
    rateLimit: {
      enabled: true,
      default: {
        windowMs: 60000,
        maxRequests: 30
      },
      byRole: {
        admin: { windowMs: 60000, maxRequests: 1000 },
        developer: { windowMs: 60000, maxRequests: 100 },
        guest: { windowMs: 60000, maxRequests: 10 }
      },
      byModel: {}
    }
  },
  
  // ============================================
  // 凭证管理
  // ============================================
  
  credentials: {
    encryption: {
      algorithm: 'aes-256-gcm',
      keySource: 'file',
      keyFile: '~/.openclaw/secure/master.key'
    },
    rotation: {
      enabled: false,
      interval: '90d',
      alertBefore: '7d'
    },
    storage: {
      type: 'file',
      file: {
        path: '~/.openclaw/secure/credentials.enc'
      }
    }
  },
  
  // ============================================
  // 审计日志
  // ============================================
  
  audit: {
    enabled: true,
    events: [
      'model-switch',
      'model-failover',
      'policy-violation',
      'credential-access'
    ],
    level: 'info',
    storage: {
      type: 'file',
      file: {
        path: '~/.openclaw/audit/model-security.log',
        rotation: {
          enabled: true,
          maxSize: '10MB',
          maxFiles: 10
        }
      }
    },
    redaction: {
      enabled: true,
      fields: ['apiKey', 'token', 'password', 'secret']
    },
    retention: {
      duration: '90d',
      archive: {
        enabled: true,
        path: '~/.openclaw/audit/archive/'
      }
    }
  }
}
